{
  "name": "pollocks",
  "version": "1.1.1",
  "description": "A TypeScript job queue library backed by PostgreSQL",
  "type": "module",
  "license": "MIT",
  "author": "Matheus Robert Lichtnow",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/robertLichtnow/pollocks.git"
  },
  "homepage": "https://github.com/robertLichtnow/pollocks#readme",
  "keywords": [
    "job-queue",
    "task-queue",
    "postgresql",
    "postgres",
    "background-jobs",
    "worker",
    "typescript"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "bunup",
    "test": "bun test",
    "lint": "oxlint",
    "migration": "bun run scripts/new-migration.ts",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "bench:add": "bun run src/benchmarks/add-jobs.ts",
    "bench:acquire": "bun run src/benchmarks/acquire-job.ts",
    "bench": "bun run bench:add && bun run bench:acquire",
    "recipe:basic": "bun run recipes/basic/run.ts",
    "recipe:nestjs": "bun run recipes/nestjs/run.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "ulid": "^3.0.2",
    "umzug": "3.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@types/bun": "1.3.9",
    "@types/pg": "8.16.0",
    "bunup": "^0.16.31",
    "husky": "^9.1.7",
    "oxlint": "1.46.0",
    "pg": "8.18.0"
  },
  "peerDependencies": {
    "typescript": "^5",
    "pg": "^8.0.0"
  }
}
